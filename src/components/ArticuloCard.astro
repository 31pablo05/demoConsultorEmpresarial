---
import type { Post } from '../types/post';

interface Props {
  post: Post;
  featured?: boolean;
  cardIndex?: number;
  hidden?: boolean;
  className?: string;
}

const {
  post,
  featured = false,
  cardIndex,
  hidden = false,
  className = '',
} = Astro.props;

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('es-AR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
}

const patternId = `art-pattern-${post.slug.replace(/[^a-zA-Z0-9-]/g, '')}-${featured ? 'featured' : 'card'}`;
---

<a
  href={`/articulos/${post.slug}`}
  data-post-card
  data-category={post.category}
  data-post-index={cardIndex}
  class:list={[
    'group flex flex-col overflow-hidden border border-line bg-bg2 transition-all duration-300 hover:border-accent/45 hover:bg-bg3',
    featured ? 'h-full' : '',
    hidden ? 'hidden' : '',
    className,
  ]}
>
  <div class:list={[
    'relative overflow-hidden bg-bg3',
    featured ? 'h-56 md:h-72' : 'h-44',
  ]}>
    {post.imageUrl ? (
      <img
        src={post.imageUrl}
        alt={post.title}
        loading="lazy"
        class="h-full w-full object-cover opacity-80 transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <>
        <svg class="absolute inset-0 h-full w-full opacity-15" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id={patternId} width="28" height="28" patternUnits="userSpaceOnUse">
              <circle cx="14" cy="14" r="1" fill="#C4974E" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill={`url(#${patternId})`} />
        </svg>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(221,185,106,0.18),transparent_60%)]"></div>
      </>
    )}

    <span class="absolute left-4 top-4 z-10 w-fit border border-accent/40 bg-accent/20 px-3 py-1 font-sans text-[10px] font-medium uppercase tracking-[0.22em] text-accent2">
      {post.category}
    </span>
  </div>

  <div class:list={[
    'flex flex-1 flex-col gap-3',
    featured ? 'p-8' : 'p-6',
  ]}>
    <div class="flex items-center gap-2 font-sans text-xs font-light text-muted">
      <time>{formatDate(post.date)}</time>
      <span>·</span>
      <span>{post.readTime} min de lectura</span>
    </div>

    <h2 class:list={[
      'font-serif font-light leading-snug text-text transition-colors duration-300 group-hover:text-accent2',
      featured ? 'text-3xl' : 'text-[1.35rem]',
    ]}>
      {post.title}
    </h2>

    <p class="line-clamp-3 flex-1 font-sans text-sm font-light leading-relaxed text-muted">
      {post.excerpt}
    </p>

    <span class="mt-2 inline-flex items-center gap-2 font-sans text-sm font-light text-accent transition-colors duration-300 group-hover:text-accent2">
      Leer articulo →
    </span>
  </div>
</a>
