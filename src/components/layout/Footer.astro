---
import { siteConfig } from '../../data/siteConfig';

const year = new Date().getFullYear();
---

<footer class="bg-text" style="border-top: 1px solid rgba(255,245,236,0.1);">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
      <!-- Marca -->
      <div class="flex flex-col gap-4">
        <a href="/#inicio">
          <img src="/logo-nogoli.png" alt="Nogolí Consulting" class="h-8 w-auto" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
          <span class="font-display text-accent hidden" style="font-size: 22px; letter-spacing: 0.05em;">{siteConfig.name}</span>
        </a>
        <p class="font-sans text-sm font-light leading-relaxed max-w-xs" style="color: rgba(255,245,236,0.6);">
          {siteConfig.tagline}
        </p>
        <!-- Social links -->
        <div class="flex gap-4 mt-1">
          <a
            href={`https://${siteConfig.linkedin}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn personal"
            class="text-accent hover:text-accent/70 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect width="4" height="12" x="2" y="9"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a
            href={`https://${siteConfig.linkedinEmpresa}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn empresa"
            class="text-accent hover:text-accent/70 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2"/>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
          </a>
          <a
            href={`https://wa.me/${siteConfig.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="text-accent hover:text-accent/70 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.45 2 2 0 0 1 3.57 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.63a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav links -->
      <div class="flex flex-col gap-3">
        <span class="font-sans text-xs font-medium tracking-widest uppercase" style="color: rgba(255,245,236,0.5);">Secciones</span>
        <nav class="flex flex-col gap-2">
          {[
            { href: '/#inicio', label: 'Inicio' },
            { href: '/#metodo', label: 'Método' },
            { href: '/#servicios', label: 'Servicios' },
            { href: '/#sobre', label: 'Sobre mí' },
            { href: '/articulos', label: 'Artículos' },
            { href: '/#contacto', label: 'Contacto' },
            { href: '/metodo', label: 'El Método completo' },
          ].map((item) => (
            <a
              href={item.href}
              class="font-sans text-sm font-light hover:text-accent transition-colors w-fit"
              style="color: rgba(255,245,236,0.7);"
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contacto -->
      <div class="flex flex-col gap-3">
        <span class="font-sans text-xs font-medium tracking-widest uppercase" style="color: rgba(255,245,236,0.5);">Contacto</span>
        <div class="flex flex-col gap-2">
          <a href={`mailto:${siteConfig.email}`} class="font-sans text-sm font-light hover:text-accent transition-colors" style="color: rgba(255,245,236,0.7);">
            {siteConfig.email}
          </a>
          <a href={`https://wa.me/${siteConfig.whatsapp}`} target="_blank" rel="noopener noreferrer" class="font-sans text-sm font-light hover:text-accent transition-colors" style="color: rgba(255,245,236,0.7);">
            {siteConfig.whatsappDisplay}
          </a>
          <a href={`https://${siteConfig.linkedin}`} target="_blank" rel="noopener noreferrer" class="font-sans text-sm font-light hover:text-accent transition-colors" style="color: rgba(255,245,236,0.7);">
            LinkedIn — Sergio Celuch
          </a>
          <a href={`https://${siteConfig.linkedinEmpresa}`} target="_blank" rel="noopener noreferrer" class="font-sans text-sm font-light hover:text-accent transition-colors" style="color: rgba(255,245,236,0.7);">
            LinkedIn — Nogolí Consulting
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-3" style="border-top: 1px solid rgba(255,245,236,0.1);">
      <p class="font-sans text-xs font-light" style="color: rgba(255,245,236,0.4);">
        &copy; {year} {siteConfig.name}. Todos los derechos reservados.
      </p>
      <p class="font-sans text-xs font-light" style="color: rgba(255,245,236,0.4);">
        Construido con <span class="text-accent">Astro</span> + Tailwind
      </p>
    </div>
  </div>
</footer>
