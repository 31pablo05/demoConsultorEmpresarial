---
import { proceso } from '../../data/proceso';
---

<section id="proceso" class="bg-bg2 py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col gap-5 mb-16 text-center">
      <div class="reveal eyebrow justify-center">Cómo trabajo</div>
      <h2 class="reveal reveal-delay-1 font-serif text-3xl md:text-4xl lg:text-5xl font-light text-text">
        Un proceso claro, sin sorpresas.
      </h2>
    </div>

    <!-- Steps -->
    <div class="relative grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Connector line (desktop) -->
      <div class="hidden lg:block absolute top-10 left-[12.5%] right-[12.5%] h-px bg-line z-0"></div>

      {proceso.map((paso, i) => (
        <div class={`reveal reveal-delay-${i + 1} relative flex flex-col items-center text-center gap-4 px-4 py-6 sm:px-6`}>
          <!-- Circle with number -->
          <div class="relative z-10 w-16 h-16 lg:w-20 lg:h-20 rounded-full border border-line bg-bg2 flex items-center justify-center flex-shrink-0">
            <span class="font-serif text-2xl lg:text-3xl font-light text-accent2">{paso.numero}</span>
          </div>

          <!-- Content -->
          <div class="flex flex-col gap-2">
            <h3 class="font-serif text-lg lg:text-xl font-light text-text">
              {paso.titulo}
            </h3>
            <p class="font-sans text-sm font-light text-muted leading-relaxed">
              {paso.descripcion}
            </p>
          </div>

          <!-- Mobile connector line (vertical between sm:hidden) -->
          {i < proceso.length - 1 && (
            <div class="sm:hidden w-px h-6 bg-line mt-1"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
