---
import { servicios } from '../../data/servicios';
---

<section id="servicios" class="bg-bg2 py-28 md:py-40">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col gap-5 mb-16 lg:mb-20">
      <div class="reveal eyebrow">Lo que hago</div>
      <h2 class="reveal reveal-delay-1 font-serif text-4xl md:text-5xl lg:text-6xl font-light text-text">
        Servicios de consultoría estratégica
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3" style="gap: 1px; background-color: var(--line);">
      {servicios.map((servicio, i) => (
        <article
          class={`reveal reveal-delay-${i + 1} group relative card-glow bg-bg2 hover:bg-bg3 transition-colors duration-500 overflow-hidden flex flex-col gap-7 p-10 lg:p-12`}
        >
          <!-- Number decoration -->
          <span
            class="absolute top-6 right-6 font-serif font-light leading-none select-none pointer-events-none"
            style="color: rgba(196,151,78,0.06); font-size: 5.5rem;"
          >
            {servicio.numero}
          </span>

          <!-- Icon -->
          <div class="text-accent w-5 h-5" set:html={servicio.icono} />

          <!-- Content -->
          <div class="flex flex-col gap-4">
            <h3 class="font-serif text-2xl font-light text-text">
              {servicio.nombre}
            </h3>
            <p class="font-sans text-sm font-light text-muted leading-loose">
              {servicio.descripcion}
            </p>
          </div>

          <!-- Bottom accent line -->
          <div
            class="absolute bottom-0 left-0 h-px bg-accent transition-all duration-500"
            style="width: 0%;"
            data-hover-line
          />
          <style>{`
            article:hover [data-hover-line] { width: 100% !important; }
          `}</style>
        </article>
      ))}
    </div>
  </div>
</section>
