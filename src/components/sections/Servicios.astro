---
import { servicios } from '../../data/servicios';
---

<section id="servicios" class="bg-bg2 py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col gap-5 mb-12 lg:mb-16">
      <div class="reveal eyebrow">Lo que hago</div>
      <h2 class="reveal reveal-delay-1 font-serif text-3xl md:text-4xl lg:text-5xl font-light text-text">
        Servicios de consultoría estratégica
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3" style="gap: 1px; background-color: var(--line);">
      {servicios.map((servicio, i) => (
        <article
          class={`reveal reveal-delay-${i + 1} group relative bg-bg2 hover:bg-bg3 transition-colors duration-300 overflow-hidden flex flex-col gap-6 p-8 lg:p-10`}
        >
          <!-- Number decoration -->
          <span
            class="absolute top-6 right-6 font-serif text-7xl font-light leading-none select-none pointer-events-none"
            style="color: rgba(94,158,114,0.07); font-size: 5rem;"
          >
            {servicio.numero}
          </span>

          <!-- Icon -->
          <div class="text-accent w-6 h-6" set:html={servicio.icono} />

          <!-- Content -->
          <div class="flex flex-col gap-3">
            <h3 class="font-serif text-xl font-light text-text">
              {servicio.nombre}
            </h3>
            <p class="font-sans text-sm font-light text-muted leading-relaxed">
              {servicio.descripcion}
            </p>
          </div>

          <!-- Bottom accent line -->
          <div
            class="absolute bottom-0 left-0 h-px bg-accent transition-all duration-300"
            style="width: 0%;"
            data-hover-line
          />
          <style>{`
            article:hover [data-hover-line] { width: 100% !important; }
          `}</style>
        </article>
      ))}
    </div>
  </div>
</section>
