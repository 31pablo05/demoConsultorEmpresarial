---
const sintomas = [
  'Sobrecarga del dueño o gerentes',
  'Decisiones que no suceden a tiempo',
  'Compromisos poco visibles',
  'Reuniones largas sin cierre',
  'Retrabajo constante',
  'Proyectos sin seguimiento claro',
];
---

<section id="desafio" class="bg-cream-mid py-28 md:py-40">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col gap-5 mb-14 text-center max-w-3xl mx-auto">
      <div class="reveal eyebrow justify-center">El problema que resolvemos</div>
      <h2 class="reveal reveal-delay-1 font-serif text-espresso" style="font-size: clamp(36px, 5vw, 52px); line-height: 1.2; letter-spacing: -0.01em;">
        Lo que antes funcionaba,<br />
        hoy no te deja crecer.
      </h2>
      <p class="reveal reveal-delay-2 font-sans text-base md:text-lg font-semibold leading-loose" style="color: var(--espresso);">
        Cuando la empresa crece, su forma de trabajar empieza a quedar chica:
      </p>
    </div>

    <!-- Symptoms grid -->
    <div class="reveal reveal-delay-2 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
      {sintomas.map((sintoma) => (
        <div class="flex items-start gap-4 p-5 bg-cream hover:bg-warm-white transition-colors duration-300" style="border-left: 4px solid var(--gold-dark);">
          <!-- Warning icon in accent -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-accent shrink-0 mt-0.5"
          >
            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
            <path d="M12 9v4"/>
            <path d="M12 17h.01"/>
          </svg>
          <span class="font-sans text-sm font-light leading-snug" style="color: var(--espresso);">{sintoma}</span>
        </div>
      ))}
    </div>

    <!-- Closing statement -->
    <p class="reveal reveal-delay-3 font-serif italic text-lg text-center mt-14 max-w-2xl mx-auto leading-relaxed" style="color: var(--dark-mid);">
      El desorden no aparece de golpe: crece en silencio mientras la empresa avanza.
    </p>
  </div>
</section>
