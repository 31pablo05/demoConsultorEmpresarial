---
const metricas = [
  {
    icon: '↓',
    valor: '20–40%',
    label: 'horas de reunión',
    direccion: 'Reducción',
  },
  {
    icon: '↓',
    valor: '',
    label: 'escalamiento al dueño/gerentes',
    direccion: 'Reducción',
  },
  {
    icon: '↑',
    valor: '',
    label: 'capacidad de entrega',
    direccion: 'Aumento',
  },
  {
    icon: '↓',
    valor: '',
    label: 'retrabajos y urgencias',
    direccion: 'Reducción',
  },
];
---

<section id="resultados" class="bg-bg py-28 md:py-40">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col gap-5 mb-16 text-center">
      <div class="reveal eyebrow justify-center">Qué lográs</div>
      <h2 class="reveal reveal-delay-1 font-display text-text uppercase" style="font-size: clamp(36px, 5vw, 72px); line-height: 1.0; letter-spacing: 0.01em;">
        Resultados concretos, no promesas.
      </h2>
    </div>

    <!-- Metrics grid -->
    <div class="reveal reveal-delay-2 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-line mb-16">
      {metricas.map((m) => (
        <div class="bg-bg2 p-8 lg:p-10 flex flex-col gap-3 hover:bg-bg3 transition-colors duration-300">
          <div class="flex items-baseline gap-2">
            <span
              class="font-serif text-2xl font-bold leading-none"
              style="color: var(--accent);"
            >
              {m.icon}
            </span>
            {m.valor && (
              <span class="font-serif text-xl font-bold text-text">{m.valor}</span>
            )}
          </div>
          <p class="font-sans text-xs font-medium tracking-widest uppercase text-muted">{m.direccion}</p>
          <p class="font-serif text-[17px] font-bold text-text leading-snug">{m.label}</p>
        </div>
      ))}
    </div>

    <!-- Conclusion text -->
    <div class="reveal reveal-delay-3 max-w-3xl mx-auto text-center">
      <p class="font-sans text-base md:text-lg font-light text-muted leading-loose">
        Ordenar la ejecución no requiere burocracia: requiere un sistema simple para
        decidir, comprometerse, ejecutar y mejorar. Al convertir coordinación y retrabajo
        en capacidad real de entrega, la organización libera tiempo del liderazgo y queda
        lista para crecer.
      </p>
    </div>
  </div>
</section>
