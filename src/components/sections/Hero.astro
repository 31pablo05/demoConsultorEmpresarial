---
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden pt-20 bg-cream">


  <!-- Diagonal pattern (encima del overlay) -->
  <div class="absolute inset-0 pointer-events-none" style="z-index: 2; background-image: url(\"data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%239e6a28' fill-opacity='0.06'%3E%3Cpath d='M0 40L40 0H20L0 20M40 40V20L20 40'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");"></div>
  <!-- Radial glows -->
  <div class="absolute inset-0 pointer-events-none" style="z-index: 2;">
    <div class="absolute top-1/3 right-0 w-md h-112 rounded-full" style="background: radial-gradient(circle, rgba(211,153,69,0.10) 0%, transparent 70%);"></div>
    <div class="absolute bottom-1/4 left-1/4 w-72 h-72 rounded-full" style="background: radial-gradient(circle, rgba(211,153,69,0.07) 0%, transparent 70%);"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 lg:px-8 w-full pt-16 pb-10 lg:py-24 flex flex-col lg:grid lg:grid-cols-2 lg:gap-20 lg:items-center" style="z-index: 3;">

    <!-- 1 · Title + Subtitle + CTAs -->
    <div class="flex flex-col gap-8 lg:gap-10">

      <!-- Headline -->
      <div class="flex flex-col gap-4">
        <h1 class="reveal font-serif" style="color: #210c04; font-size: clamp(42px, 6vw, 72px); line-height: 1.05; letter-spacing: -0.03em; font-weight: 900;">
          Orden sin burocracia.
        </h1>
        <div class="reveal" style="width: 48px; height: 3px; background: var(--accent);"></div>
      </div>

      <!-- Subheading -->
      <div class="reveal reveal-delay-1 max-w-md">
        <p class="font-sans text-lg md:text-xl font-semibold leading-snug" style="color: rgba(33,12,4,0.85);">
          Tu empresa cambi&oacute;.<br />Tu forma de trabajar, no.
        </p>
      </div>

      <!-- CTAs (desktop only — mobile version is below the photo) -->
      <div class="reveal reveal-delay-2 hidden lg:flex flex-wrap gap-4 items-center">
        <a
          href="#contacto"
          class="btn-shimmer inline-flex items-center gap-2 px-8 py-4 bg-gold-dark text-cream font-sans text-sm font-medium tracking-wide hover:bg-accent transition-colors duration-300"
        >
          Hablemos
        </a>
        <a
          href="#metodo"
          class="inline-flex items-center gap-2 px-8 py-4 font-sans text-sm font-light tracking-wide border transition-all duration-300" style="color: #210c04; border-color: rgba(33,12,4,0.40);" onmouseover="this.style.background='rgba(33,12,4,0.06)'" onmouseout="this.style.background=''"
        >
          Conocé el Método →
        </a>
      </div>

    </div>

    <!-- 2 · Foto -->
    <div class="reveal reveal-delay-1 relative flex justify-center lg:justify-end mt-10 lg:mt-0">
      <div class="relative w-full max-w-sm lg:max-w-none lg:w-auto lg:overflow-visible overflow-hidden">
        <!-- Offset decorative border (solo desktop) -->
        <div class="hidden lg:block absolute -top-4 -right-4 w-full h-full border-2 border-accent/40 z-0"></div>

        <!-- Hero image -->
        <div class="relative z-10 w-full aspect-[4/5] lg:w-105 lg:h-135 lg:aspect-auto overflow-hidden bg-bg2">
          <img
            src="/imagenes/perfil/sergio6.jpg"
            alt="Sergio Martín Celuch — Nogolí Consulting"
            class="w-full h-full object-cover object-top"
            loading="eager"
            fetchpriority="high"
            width="840"
            height="1050"
          />
          <!-- Warm tint overlay -->
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(33,12,4,0.15) 0%, transparent 60%);"></div>
        </div>
      </div>
    </div>

    <!-- CTAs (mobile only — shown below photo) -->
    <div class="lg:hidden reveal reveal-delay-2 flex flex-wrap gap-4 items-center mt-8">
        <a
          href="#contacto"
          class="btn-shimmer inline-flex items-center gap-2 px-8 py-4 bg-gold-dark text-cream font-sans text-sm font-medium tracking-wide hover:bg-accent transition-colors duration-300"
        >
          Hablemos
        </a>
        <a
          href="#metodo"
          class="inline-flex items-center gap-2 px-8 py-4 font-sans text-sm font-light tracking-wide border transition-all duration-300" style="color: #210c04; border-color: rgba(33,12,4,0.40);" onmouseover="this.style.background='rgba(33,12,4,0.06)'" onmouseout="this.style.background=''"
        >
          Conocé el Método →
        </a>
      </div>

  </div>


</section>
