---
---

<section id="inicio" class="relative min-h-screen flex items-center bg-bg overflow-hidden pt-20">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 right-0 w-[32rem] h-[32rem] rounded-full bg-accent/4 blur-3xl animate-float-1"></div>
    <div class="absolute bottom-1/4 left-1/4 w-72 h-72 rounded-full bg-accent/3 blur-3xl animate-float-2"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 lg:px-8 w-full pt-20 pb-28 lg:py-28 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
    <!-- Left: Text -->
    <div class="flex flex-col gap-10">
      <!-- Eyebrow -->
      <div class="reveal eyebrow">
        Consultor Estratégico Empresarial
      </div>

      <!-- Headline -->
      <h1 class="reveal reveal-delay-1 font-serif text-5xl sm:text-6xl md:text-7xl xl:text-[5.25rem] font-light text-text">
        Claridad estratégica<br />
        para <em class="gradient-text">crecer</em> con foco.
      </h1>

      <!-- Subheading -->
      <p class="reveal reveal-delay-2 font-sans text-base md:text-lg font-light text-muted max-w-md leading-loose">
        Acompaño a empresas y equipos directivos a definir su rumbo,
        tomar mejores decisiones y ejecutar con resultados concretos.
      </p>

      <!-- CTAs -->
      <div class="reveal reveal-delay-3 flex flex-wrap gap-5 items-center">
        <a
          href="#contacto"
          class="btn-shimmer inline-flex items-center gap-2 px-8 py-4 bg-accent text-bg font-sans text-sm font-medium tracking-wide hover:bg-accent2 transition-colors duration-500"
        >
          Agendá una llamada
        </a>
        <a
          href="#articulos"
          class="inline-flex items-center gap-2 px-8 py-4 font-sans text-sm font-light tracking-wide text-muted hover:text-text border border-transparent hover:border-line transition-all duration-500"
        >
          Ver artículos →
        </a>
      </div>
    </div>

    <!-- Right: Image placeholder with decorative frame -->
    <div class="reveal reveal-delay-2 relative flex justify-center lg:justify-end">
      <div class="relative w-full max-w-sm lg:max-w-none lg:w-auto">
        <!-- Offset decorative borders -->
        <div class="absolute -top-5 -right-5 w-full h-full border border-accent/25 z-0"></div>
        <div class="absolute -top-2.5 -right-2.5 w-full h-full border border-accent/12 z-0"></div>

        <!-- Image placeholder -->
        <div class="relative z-10 w-full h-72 sm:h-96 lg:w-96 lg:h-[520px] bg-bg3 border border-line flex items-center justify-center overflow-hidden">
          <!-- Decorative pattern -->
          <svg class="absolute inset-0 w-full h-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <pattern id="grid-hero" width="40" height="40" patternUnits="userSpaceOnUse">
                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#C4974E" stroke-width="0.5"/>
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#grid-hero)"/>
          </svg>
          <span class="font-sans text-xs text-muted tracking-[0.2em] uppercase z-10">Foto de Sergio</span>
        </div>

        <!-- Stats floating card -->
        <div class="absolute -bottom-10 left-0 lg:-bottom-8 lg:-left-8 z-20 bg-bg2 border border-line px-5 py-4 lg:px-8 lg:py-5 flex gap-5 lg:gap-8">
          <div class="flex flex-col items-center gap-1">
            <span class="font-serif text-2xl lg:text-3xl font-light text-accent2" data-count="40" data-prefix="+">+40</span>
            <span class="font-sans text-xs text-muted font-light tracking-widest uppercase">empresas</span>
          </div>
          <div class="w-px bg-line"></div>
          <div class="flex flex-col items-center gap-1">
            <span class="font-serif text-2xl lg:text-3xl font-light text-accent2" data-count="12">12</span>
            <span class="font-sans text-xs text-muted font-light tracking-widest uppercase">años</span>
          </div>
          <div class="w-px bg-line"></div>
          <div class="flex flex-col items-center gap-1">
            <span class="font-serif text-2xl lg:text-3xl font-light text-accent2" data-count="8">8</span>
            <span class="font-sans text-xs text-muted font-light tracking-widest uppercase">industrias</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
