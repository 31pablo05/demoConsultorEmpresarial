---
---

<section id="inicio" class="relative min-h-screen flex items-center bg-bg overflow-hidden pt-20">
  <!-- Subtle warm texture overlay -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 right-0 w-md h-112 rounded-full" style="background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);"></div>
    <div class="absolute bottom-1/4 left-1/4 w-72 h-72 rounded-full" style="background: radial-gradient(circle, rgba(201,168,76,0.05) 0%, transparent 70%);"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 lg:px-8 w-full pt-16 pb-28 lg:py-24 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
    <!-- Left: Text -->
    <div class="flex flex-col gap-8">
      <!-- Eyebrow -->
      <div class="reveal eyebrow">
        Consultor en Gestión Operacional
      </div>

      <!-- Headline -->
      <h1 class="reveal reveal-delay-1 font-serif text-5xl sm:text-6xl md:text-7xl xl:text-[5rem] font-light text-text">
        Ordenar la ejecución<br />
        para <em class="gradient-text">crecer.</em>
      </h1>

      <!-- Subheading -->
      <p class="reveal reveal-delay-2 font-sans text-base md:text-lg font-light text-muted max-w-md leading-loose">
        Nogolí Consulting ayuda a organizaciones a ordenar su ejecución y crecer,
        sin sumar burocracia, transformando fricción interna y retrabajo en
        capacidad real de entrega.
      </p>

      <!-- CTAs -->
      <div class="reveal reveal-delay-3 flex flex-wrap gap-4 items-center">
        <a
          href="#contacto"
          class="btn-shimmer inline-flex items-center gap-2 px-8 py-4 bg-accent text-bg font-sans text-sm font-medium tracking-wide hover:bg-accent2 transition-colors duration-500"
        >
          Hablemos
        </a>
        <a
          href="#metodo"
          class="inline-flex items-center gap-2 px-8 py-4 font-sans text-sm font-light tracking-wide text-muted border border-line hover:border-accent hover:text-text transition-all duration-500"
        >
          Conocé el Método →
        </a>
      </div>

      <!-- Stats -->
      <div class="reveal reveal-delay-4 flex items-center gap-2 flex-wrap">
        <span class="font-sans text-xs font-light text-muted tracking-widest uppercase border border-line px-4 py-2">
          3 años
        </span>
        <span class="font-sans text-xs font-light text-muted tracking-widest uppercase border border-line px-4 py-2">
          PyMEs y grandes empresas
        </span>
        <span class="font-sans text-xs font-light text-muted tracking-widest uppercase border border-line px-4 py-2">
          Buenos Aires
        </span>
      </div>
    </div>

    <!-- Right: Photo -->
    <div class="reveal reveal-delay-2 relative flex justify-center lg:justify-end">
      <div class="relative w-full max-w-sm lg:max-w-none lg:w-auto">
        <!-- Offset decorative borders -->
        <div class="absolute -top-4 -right-4 w-full h-full border border-accent/30 z-0"></div>

        <!-- Hero image -->
        <div class="relative z-10 w-full h-72 sm:h-96 lg:w-105 lg:h-135 overflow-hidden bg-bg3">
          <img
            src="/fotos/sergio-hero.jpg"
            alt="Sergio Martín Celuch — Nogolí Consulting"
            class="w-full h-full object-cover object-center"
            loading="eager"
          />
          <!-- Warm tint overlay -->
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(44,26,14,0.15) 0%, transparent 60%);"></div>
        </div>

        <!-- Floating info card -->
        <div class="absolute -bottom-8 left-0 lg:-bottom-6 lg:-left-10 z-20 bg-bg2 border border-line px-6 py-4">
          <p class="font-serif text-sm font-light text-text leading-snug">
            "Ordenar la ejecución<br />para crecer."
          </p>
          <p class="font-sans text-[10px] text-muted uppercase tracking-widest mt-2">Nogolí Consulting</p>
        </div>
      </div>
    </div>
  </div>
</section>
