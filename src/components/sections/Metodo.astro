<style>
  /* Phase node hover */
  .phase-node .phase-hint { opacity: 0; transition: opacity 0.2s; }
  .phase-node:hover .phase-hint { opacity: 1; }
  .phase-node:hover .phase-circle { background: var(--cream) !important; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }

  /* Phase node active state */
