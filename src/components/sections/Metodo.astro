</style>

<script>
  let openFaseId: string | null = null;
  let openPilarId: string | null = null;

  function toggleFase(id: string) {
    const panel = document.getElementById(id) as HTMLElement | null;
    const node  = document.querySelector(`.phase-node[data-fase="${id}"]`) as HTMLElement | null;
    if (!panel) return;

    if (openFaseId && openFaseId !== id) {
      const prev = document.getElementById(openFaseId) as HTMLElement | null;
      const prevNode = document.querySelector(`.phase-node[data-fase="${openFaseId}"]`) as HTMLElement | null;
      if (prev) prev.style.maxHeight = '0';
      if (prevNode) prevNode.classList.remove('active');
    }

    const isOpen = panel.style.maxHeight !== '0px' && panel.style.maxHeight !== '';
    if (isOpen) {
      panel.style.maxHeight = '0';
      if (node) node.classList.remove('active');
      openFaseId = null;
    } else {
      panel.style.maxHeight = '400px';
      if (node) node.classList.add('active');
      openFaseId = id;
    }
  }

  function togglePilar(id: string) {
    const panel = document.getElementById(id) as HTMLElement | null;
    const tag   = document.querySelector(`.pilar-tag[data-pilar="${id}"]`) as HTMLElement | null;
    if (!panel) return;

    if (openPilarId && openPilarId !== id) {
      const prev = document.getElementById(openPilarId) as HTMLElement | null;
      const prevTag = document.querySelector(`.pilar-tag[data-pilar="${openPilarId}"]`) as HTMLElement | null;
      if (prev) prev.style.maxHeight = '0';
      if (prevTag) prevTag.classList.remove('active');
    }

    const isOpen = panel.style.maxHeight !== '0px' && panel.style.maxHeight !== '';
    if (isOpen) {
      panel.style.maxHeight = '0';
      if (tag) tag.classList.remove('active');
      openPilarId = null;
    } else {
      panel.style.maxHeight = '400px';
      if (tag) tag.classList.add('active');
      openPilarId = id;
    }
  }

  function toggleStep(id: string) {
    const body   = document.getElementById(id) as HTMLElement | null;
    const item   = body?.closest('.step-item') as HTMLElement | null;
    if (!body || !item) return;
    const isOpen = body.style.display !== 'none';
    body.style.display = isOpen ? 'none' : 'block';
    item.classList.toggle('open', !isOpen);
  }

  function openMobileModal(templateId: string) {
    const tpl     = document.getElementById(templateId) as HTMLTemplateElement | null;
    const overlay = document.getElementById('mobile-modal-overlay') as HTMLElement | null;
    const content = document.getElementById('mobile-modal-content') as HTMLElement | null;
    if (!tpl || !overlay || !content) return;
    content.innerHTML = '';
    content.appendChild(tpl.content.cloneNode(true));
    overlay.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeMobileModal() {
    const overlay = document.getElementById('mobile-modal-overlay') as HTMLElement | null;
    if (!overlay) return;
    overlay.style.display = 'none';
    document.body.style.overflow = '';
  }

  // Expose to inline onclick handlers
  (window as any).toggleFase = toggleFase;
  (window as any).togglePilar = togglePilar;
  (window as any).toggleStep = toggleStep;
  (window as any).openMobileModal = openMobileModal;
  (window as any).closeMobileModal = closeMobileModal;
</script>
