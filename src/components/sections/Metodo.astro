<section id="metodo" class="bg-cream py-28 md:py-40">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="flex flex-col gap-5 mb-16">
      <h2 class="reveal font-serif text-espresso max-w-3xl" style="font-size: clamp(36px, 5vw, 52px); line-height: 1.2; letter-spacing: -0.01em;">
         El Método Nogolí.
      </h2>
      <p class="reveal reveal-delay-2 font-sans text-base md:text-lg font-light max-w-2xl leading-loose" style="color: var(--dark-mid);">
        Entrenamos a tu empresa para que evolucione y pueda crecer sin sumar burocracia.
        Trabajamos con dueños, directivos y equipos para que, en ese camino de evolución,
        construyan orden: procesos simples, roles claros y expectativas concretas, apoyados
        en sistemas de gestión que no ahogan, sino que ayudan a decidir mejor e innovar más
      . Así, tu empresa deja de depender solo del héroe de turno y pasa a apoyarse
        en un sistema que cuida el negocio de hoy y habilita el de mañana.
      </p>
    </div>

    <!-- â•â•â• DESKTOP: Phase flow â•â•â• -->
    <div class="hidden lg:block reveal mb-4">
      <div class="phase-flow relative flex items-start justify-center gap-0">
        <!-- horizontal line behind circles -->
        <div class="absolute" style="top:26px;left:0;right:0;height:1px;background:var(--accent);opacity:0.2;pointer-events:none;"></div>

        <!-- Phase 01 -->
        <div class="phase-node flex flex-col items-center gap-2 cursor-pointer flex-1 px-3" data-fase="fase-1" onclick="toggleFase('fase-1')">
          <div class="phase-circle flex items-center justify-center" style="width:52px;height:52px;border-radius:50%;background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);transition:all 0.2s;position:relative;z-index:1;">
            <span class="phase-num font-serif font-bold text-sm" style="color:var(--accent);">01</span>
          </div>
          <span class="font-serif font-bold text-espresso text-xs text-center">Diagnóstico</span>
          <span class="font-sans text-[10px] text-center leading-snug" style="color:var(--dark-mid);max-width:90px;">Entendemos la realidad operativa actual</span>
          <span class="phase-hint font-sans text-[9px]" style="color:var(--accent);">ver detalle ↓</span>
        </div>
        <div class="shrink-0 pt-4 font-sans text-base" style="color:var(--accent);opacity:0.5;">→</div>

        <!-- Phase 02 -->
        <div class="phase-node flex flex-col items-center gap-2 cursor-pointer flex-1 px-3" data-fase="fase-2" onclick="toggleFase('fase-2')">
          <div class="phase-circle flex items-center justify-center" style="width:52px;height:52px;border-radius:50%;background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);transition:all 0.2s;position:relative;z-index:1;">
            <span class="phase-num font-serif font-bold text-sm" style="color:var(--accent);">02</span>
          </div>
          <span class="font-serif font-bold text-espresso text-xs text-center">Adaptación</span>
          <span class="font-sans text-[10px] text-center leading-snug" style="color:var(--dark-mid);max-width:90px;">Diseñamos el sistema para tu empresa</span>
          <span class="phase-hint font-sans text-[9px]" style="color:var(--accent);">ver detalle ↓</span>
        </div>
        <div class="shrink-0 pt-4 font-sans text-base" style="color:var(--accent);opacity:0.5;">→</div>

        <!-- Phase 03 -->
        <div class="phase-node flex flex-col items-center gap-2 cursor-pointer flex-1 px-3" data-fase="fase-3" onclick="toggleFase('fase-3')">
          <div class="phase-circle flex items-center justify-center" style="width:52px;height:52px;border-radius:50%;background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);transition:all 0.2s;position:relative;z-index:1;">
            <span class="phase-num font-serif font-bold text-sm" style="color:var(--accent);">03</span>
          </div>
          <span class="font-serif font-bold text-espresso text-xs text-center">Implementación</span>
          <span class="font-sans text-[10px] text-center leading-snug" style="color:var(--dark-mid);max-width:90px;">Instalamos con el equipo, no para el equipo</span>
          <span class="phase-hint font-sans text-[9px]" style="color:var(--accent);">ver detalle ↓</span>
        </div>
        <div class="shrink-0 pt-4 font-sans text-base" style="color:var(--accent);opacity:0.5;">→</div>

        <!-- Phase 04 -->
        <div class="phase-node flex flex-col items-center gap-2 cursor-pointer flex-1 px-3" data-fase="fase-4" onclick="toggleFase('fase-4')">
          <div class="phase-circle flex items-center justify-center" style="width:52px;height:52px;border-radius:50%;background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);transition:all 0.2s;position:relative;z-index:1;">
            <span class="phase-num font-serif font-bold text-sm" style="color:var(--accent);">04</span>
          </div>
          <span class="font-serif font-bold text-espresso text-xs text-center">Seguimiento</span>
          <span class="font-sans text-[10px] text-center leading-snug" style="color:var(--dark-mid);max-width:90px;">Para que el sistema se sostenga</span>
          <span class="phase-hint font-sans text-[9px]" style="color:var(--accent);">ver detalle ↓</span>
        </div>
      </div>

      <!-- Phase detail panels -->
      <div id="fase-1" class="fase-panel overflow-hidden" style="max-height:0;transition:max-height 0.3s ease;">
        <div class="mt-4 p-6 rounded-sm" style="background:var(--bg2);border-left:3px solid var(--accent);">
          <div class="flex items-start justify-between mb-4">
            <div>
              <span class="font-sans text-[9px] tracking-widest uppercase block mb-1" style="color:var(--accent);">Etapa 01</span>
              <h3 class="font-serif font-bold text-xl" style="color:var(--cream);">Diagnóstico</h3>
            </div>
            <button onclick="toggleFase('fase-1')" class="font-sans text-[10px] px-2 py-1 cursor-pointer shrink-0" style="border:1px solid var(--accent);color:var(--accent);background:transparent;">✕ cerrar</button>
          </div>
          <p class="font-sans text-sm leading-loose mb-4" style="color:rgba(250,243,228,0.8);">Entendemos la realidad operativa actual de tu empresa. Mapeamos cómo usa el tiempo la dirección, dónde está la fricción y cuáles son los problemas que más pesan al equipo.</p>
          <div class="flex flex-wrap gap-2">
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Mapeo del tiempo directivo</span>
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Relevamiento de procesos actuales</span>
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Identificación de cuellos de botella</span>
          </div>
        </div>
      </div>

      <div id="fase-2" class="fase-panel overflow-hidden" style="max-height:0;transition:max-height 0.3s ease;">
        <div class="mt-4 p-6 rounded-sm" style="background:var(--bg2);border-left:3px solid var(--accent);">
          <div class="flex items-start justify-between mb-4">
            <div>
              <span class="font-sans text-[9px] tracking-widest uppercase block mb-1" style="color:var(--accent);">Etapa 02</span>
              <h3 class="font-serif font-bold text-xl" style="color:var(--cream);">Adaptación</h3>
            </div>
            <button onclick="toggleFase('fase-2')" class="font-sans text-[10px] px-2 py-1 cursor-pointer shrink-0" style="border:1px solid var(--accent);color:var(--accent);background:transparent;">✕ cerrar</button>
          </div>
          <p class="font-sans text-sm leading-loose mb-4" style="color:rgba(250,243,228,0.8);">Con el diagnóstico en mano, diseñamos el sistema de trabajo que tu organización necesita. No copiamos plantillas: diseñamos para la realidad del equipo.</p>
          <div class="flex flex-wrap gap-2">
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Diseño del sistema operativo</span>
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Definición de roles y responsabilidades</span>
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Plan de implementación por prioridad</span>
          </div>
        </div>
      </div>

      <div id="fase-3" class="fase-panel overflow-hidden" style="max-height:0;transition:max-height 0.3s ease;">
        <div class="mt-4 p-6 rounded-sm" style="background:var(--bg2);border-left:3px solid var(--accent);">
          <div class="flex items-start justify-between mb-4">
            <div>
              <span class="font-sans text-[9px] tracking-widest uppercase block mb-1" style="color:var(--accent);">Etapa 03</span>
              <h3 class="font-serif font-bold text-xl" style="color:var(--cream);">Implementación</h3>
            </div>
            <button onclick="toggleFase('fase-3')" class="font-sans text-[10px] px-2 py-1 cursor-pointer shrink-0" style="border:1px solid var(--accent);color:var(--accent);background:transparent;">✕ cerrar</button>
          </div>
          <p class="font-sans text-sm leading-loose mb-4" style="color:rgba(250,243,228,0.8);">Instalamos el sistema con el equipo, no para el equipo. Sprint I de orden rápido, Consolidación del sistema, y Sistema Vivo con norma ISO 9001 para empresas que lo necesiten.</p>
          <div class="flex flex-wrap gap-2">
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Sprint I — orden y ejecución inmediata</span>
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Consolidación del sistema instalado</span>
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Sistema Vivo ISO 9001</span>
          </div>
        </div>
      </div>

      <div id="fase-4" class="fase-panel overflow-hidden" style="max-height:0;transition:max-height 0.3s ease;">
        <div class="mt-4 p-6 rounded-sm" style="background:var(--bg2);border-left:3px solid var(--accent);">
          <div class="flex items-start justify-between mb-4">
            <div>
              <span class="font-sans text-[9px] tracking-widest uppercase block mb-1" style="color:var(--accent);">Etapa 04</span>
              <h3 class="font-serif font-bold text-xl" style="color:var(--cream);">Seguimiento</h3>
            </div>
            <button onclick="toggleFase('fase-4')" class="font-sans text-[10px] px-2 py-1 cursor-pointer shrink-0" style="border:1px solid var(--accent);color:var(--accent);background:transparent;">✕ cerrar</button>
          </div>
          <p class="font-sans text-sm leading-loose mb-4" style="color:rgba(250,243,228,0.8);">Auditorías livianas y mentoría estratégica para que el sistema no se abandone y el equipo siga creciendo con autonomía real.</p>
          <div class="flex flex-wrap gap-2">
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Mentoría estratégica para dirección</span>
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Auditorías de mantenimiento livianas</span>
            <span class="font-sans text-[10px] px-3 py-1 rounded-sm" style="background:rgba(201,164,96,0.1);border:1px solid rgba(201,164,96,0.2);color:#E8D5A3;">Rituales de mejora continua</span>
          </div>
        </div>
      </div>
    </div><!-- end desktop flow -->

    <!-- â•â•â• MOBILE: Vertical journey â•â•â• -->
    <div class="lg:hidden flex flex-col gap-0 reveal mb-4">

      <!-- Step 1 -->
      <div class="step-item relative" style="padding-left:36px;padding-bottom:28px;">
        <div class="step-line absolute" style="left:14px;top:32px;bottom:0;width:1px;background:rgba(201,164,96,0.3);"></div>
        <div class="step-circle absolute flex items-center justify-center" style="left:0;top:0;width:30px;height:30px;border-radius:50%;background:var(--cream-mid);border:1.5px solid var(--accent);">
          <span class="step-num font-sans font-bold text-[10px]" style="color:var(--accent);">01</span>
        </div>
        <div class="step-header flex justify-between items-center cursor-pointer py-1" onclick="toggleStep('step-1')">
          <span class="font-serif font-bold text-sm text-espresso">Diagnóstico</span>
          <span class="step-arrow font-sans text-base" style="color:var(--accent);transition:transform 0.2s;">▾</span>
        </div>
        <div id="step-1" class="step-body" style="display:none;">
          <p class="font-sans leading-relaxed mt-2 mb-2" style="font-size:11px;color:var(--dark-mid);">Entendemos la realidad operativa actual de tu empresa. Mapeamos cómo usa el tiempo la dirección, dónde está la fricción y cuáles son los problemas que más pesan al equipo.</p>
          <div style="border-top:1px solid var(--line);margin:6px 0;"></div>
          <span class="font-sans uppercase tracking-widest block mb-1" style="font-size:8px;color:var(--dark-mid);">Entregable</span>
          <div class="flex flex-wrap gap-1 mb-2">
            <span class="font-sans text-[10px] text-espresso px-2 py-1 rounded-sm" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);">Mapeo del tiempo directivo</span>
            <span class="font-sans text-[10px] text-espresso px-2 py-1 rounded-sm" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);">Relevamiento de procesos</span>
            <span class="font-sans text-[10px] text-espresso px-2 py-1 rounded-sm" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);">Cuellos de botella</span>
          </div>
          <div style="border-top:1px solid var(--line);margin:6px 0;"></div>
          <span class="font-sans uppercase tracking-widest block mb-1" style="font-size:8px;color:var(--dark-mid);">Pilares activos</span>
          <div class="flex flex-wrap gap-1">
            <span class="font-sans text-[10px] text-espresso px-2 py-1 cursor-pointer" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);border-bottom:2px solid var(--accent);border-radius:3px;" onclick="openMobileModal('m-pilar-1')">Liberación del tiempo directivo</span>
          </div>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="step-item relative" style="padding-left:36px;padding-bottom:28px;">
        <div class="step-line absolute" style="left:14px;top:32px;bottom:0;width:1px;background:rgba(201,164,96,0.3);"></div>
        <div class="step-circle absolute flex items-center justify-center" style="left:0;top:0;width:30px;height:30px;border-radius:50%;background:var(--cream-mid);border:1.5px solid var(--accent);">
          <span class="step-num font-sans font-bold text-[10px]" style="color:var(--accent);">02</span>
        </div>
        <div class="step-header flex justify-between items-center cursor-pointer py-1" onclick="toggleStep('step-2')">
          <span class="font-serif font-bold text-sm text-espresso">Adaptación</span>
          <span class="step-arrow font-sans text-base" style="color:var(--accent);transition:transform 0.2s;">▾</span>
        </div>
        <div id="step-2" class="step-body" style="display:none;">
          <p class="font-sans leading-relaxed mt-2 mb-2" style="font-size:11px;color:var(--dark-mid);">Con el diagnóstico en mano, diseñamos el sistema de trabajo que tu organización necesita. No copiamos plantillas: diseñamos para la realidad del equipo.</p>
          <div style="border-top:1px solid var(--line);margin:6px 0;"></div>
          <span class="font-sans uppercase tracking-widest block mb-1" style="font-size:8px;color:var(--dark-mid);">Entregable</span>
          <div class="flex flex-wrap gap-1 mb-2">
            <span class="font-sans text-[10px] text-espresso px-2 py-1 rounded-sm" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);">Diseño del sistema operativo</span>
            <span class="font-sans text-[10px] text-espresso px-2 py-1 rounded-sm" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);">Roles y responsabilidades</span>
            <span class="font-sans text-[10px] text-espresso px-2 py-1 rounded-sm" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);">Plan de implementación</span>
          </div>
          <div style="border-top:1px solid var(--line);margin:6px 0;"></div>
          <span class="font-sans uppercase tracking-widest block mb-1" style="font-size:8px;color:var(--dark-mid);">Pilares activos</span>
          <div class="flex flex-wrap gap-1">
            <span class="font-sans text-[10px] text-espresso px-2 py-1 cursor-pointer" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);border-bottom:2px solid var(--accent);border-radius:3px;" onclick="openMobileModal('m-pilar-1')">Liberación del tiempo directivo</span>
            <span class="font-sans text-[10px] text-espresso px-2 py-1 cursor-pointer" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);border-bottom:2px solid var(--accent);border-radius:3px;" onclick="openMobileModal('m-pilar-2')">Traducción Organizacional</span>
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="step-item relative" style="padding-left:36px;padding-bottom:28px;">
        <div class="step-line absolute" style="left:14px;top:32px;bottom:0;width:1px;background:rgba(201,164,96,0.3);"></div>
        <div class="step-circle absolute flex items-center justify-center" style="left:0;top:0;width:30px;height:30px;border-radius:50%;background:var(--cream-mid);border:1.5px solid var(--accent);">
          <span class="step-num font-sans font-bold text-[10px]" style="color:var(--accent);">03</span>
        </div>
        <div class="step-header flex justify-between items-center cursor-pointer py-1" onclick="toggleStep('step-3')">
          <span class="font-serif font-bold text-sm text-espresso">Implementación</span>
          <span class="step-arrow font-sans text-base" style="color:var(--accent);transition:transform 0.2s;">▾</span>
        </div>
        <div id="step-3" class="step-body" style="display:none;">
          <p class="font-sans leading-relaxed mt-2 mb-2" style="font-size:11px;color:var(--dark-mid);">Instalamos el sistema con el equipo, no para el equipo. Sprint I de orden rápido, Consolidación del sistema, y Sistema Vivo con norma ISO 9001.</p>
          <div style="border-top:1px solid var(--line);margin:6px 0;"></div>
          <span class="font-sans uppercase tracking-widest block mb-1" style="font-size:8px;color:var(--dark-mid);">Entregables</span>
          <div class="flex flex-wrap gap-1 mb-2">
            <span class="font-sans text-[10px] text-espresso px-2 py-1 rounded-sm" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);">Sprint I</span>
            <span class="font-sans text-[10px] text-espresso px-2 py-1 rounded-sm" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);">Consolidación</span>
            <span class="font-sans text-[10px] text-espresso px-2 py-1 rounded-sm" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);">Sistema Vivo ISO 9001</span>
          </div>
          <div style="border-top:1px solid var(--line);margin:6px 0;"></div>
          <span class="font-sans uppercase tracking-widest block mb-1" style="font-size:8px;color:var(--dark-mid);">Pilares activos</span>
          <div class="flex flex-wrap gap-1">
            <span class="font-sans text-[10px] text-espresso px-2 py-1 cursor-pointer" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);border-bottom:2px solid var(--accent);border-radius:3px;" onclick="openMobileModal('m-pilar-1')">Liberación del tiempo directivo</span>
            <span class="font-sans text-[10px] text-espresso px-2 py-1 cursor-pointer" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);border-bottom:2px solid var(--accent);border-radius:3px;" onclick="openMobileModal('m-pilar-2')">Traducción Organizacional</span>
            <span class="font-sans text-[10px] text-espresso px-2 py-1 cursor-pointer" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);border-bottom:2px solid var(--accent);border-radius:3px;" onclick="openMobileModal('m-pilar-3')">Confianza y Liderazgo</span>
            <span class="font-sans text-[10px] text-espresso px-2 py-1 cursor-pointer" style="background:var(--cream-mid);border:1px solid rgba(211,153,69,0.25);border-bottom:2px solid var(--accent);border-radius:3px;" onclick="openMobileModal('m-pilar-4')">Comunicación y Coordinación</span>
          </div>
        </div>
      </div>

      <!-- Step 4 (no connecting line) -->
      <div class="step-item relative" style="padding-left:36px;padding-bottom:28px;">
        <div class="step-circle absolute flex items-center justify-center" style="left:0;top:0;width:30px;height:30px;border-radius:50%;background:var(--cream-mid);border:1.5px solid var(--accent);">
          <span class="step-num font-sans font-bold text-[10px]" style="color:var(--accent);">04</span>
        </div>
        <div class="step-header flex justify-between items-center cursor-pointer py-1" onclick="toggleStep('step-4')">
          <span class="font-serif font-bold text-sm text-espresso">Seguimiento</span>
          <span class="step-arrow font-sans text-base" style="color:var(--accent);transition:transform 0.2s;">▾</span>
        </div>
